# Runtime profile
# economy_core is the recommended default for local review: no external LLM is required.
RUNTIME_PROFILE=economy_core

# Docker build mode
# Keep false for the lightweight default build.
INSTALL_FULL=false
EXTRA_REQUIREMENTS=requirements.txt

# Basic local mode: no external LLM.
LLM_PROVIDER=offline
ENABLE_LLM=false

# Knowledge graph backend
KG_BACKEND=auto

# Local Neo4j service from docker-compose
NEO4J_DOCKER_URI=bolt://neo4j:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hackathon_password
NEO4J_DATABASE=neo4j

# Local Qdrant service from docker-compose
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=documents
QDRANT_URL=http://qdrant:6333

# Local runtime paths inside containers
DATA_DIR=/data
METADATA_DB_PATH=/data/outbox.sqlite3
CATALOG_DB_PATH=/data/catalog.sqlite3

# Optional local embedding model path.
# Leave empty for economy_core.
EMBEDDING_MODEL_PATH=
SENTENCE_TRANSFORMERS_HOME=/models
HF_HOME=/models/hf
TRANSFORMERS_OFFLINE=0
