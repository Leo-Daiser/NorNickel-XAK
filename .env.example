# Example environment configuration for the hackathon project

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Neo4j
# Local host run: bolt://localhost:7687
# Docker compose network: bolt://neo4j:7687
KG_BACKEND=auto
NEO4J_URI=bolt://localhost:7687
# Optional Docker-only override for the api container. Usually leave as default.
NEO4J_DOCKER_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Resource/runtime profile: economy_core | economy_guarded_llm | balanced_hybrid | quality_full
RUNTIME_PROFILE=economy_core
RESOURCE_STRICT=false
RESOURCE_MAX_IMAGE_GB=5

# Parser/extraction/answer runtime.
# Explicit values below override RUNTIME_PROFILE defaults.
PARSER_BACKEND=auto
EXTRACTION_MODE=deterministic
EXTRACTION_ENABLE_LLM=false
ANSWER_SYNTHESIS_MODE=template

# Embedding models. MiniLM is the CPU-friendly Phase 1 default.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Optional offline model directory mounted into Docker.
# Example:
#   models/sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 -> /models/sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#   EMBEDDING_MODEL_PATH=/models/sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#   TRANSFORMERS_OFFLINE=1
EMBEDDING_MODEL_PATH=
SENTENCE_TRANSFORMERS_HOME=/models
HF_HOME=/models/hf
TRANSFORMERS_OFFLINE=0
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Data directory for uploaded files
DATA_DIR=data
# Operational metadata / outbox
METADATA_DB_PATH=data/outbox.sqlite3
CATALOG_DB_PATH=data/catalog.sqlite3
DIRECT_QDRANT_PROJECTION=false
# Docker build: set to requirements-embeddings.txt to install sentence-transformers.
EXTRA_REQUIREMENTS=requirements.txt

# Streamlit UI backend URL
API_BASE=http://localhost:8000

# Retrieval modes: bm25 | embedding | hybrid
RETRIEVAL_MODE=bm25
# CPU/GPU local dense index without Qdrant. Requires sentence-transformers and cached/downloadable model.
ENABLE_LOCAL_EMBEDDINGS=false
# Keep startup fast. Local embeddings are built lazily on first dense query.
EAGER_LOCAL_EMBEDDINGS=false
# Deterministic synonym expansion for Russian/English technical terms.
RETRIEVAL_QUERY_EXPANSION=true

# Optional grounded LLM answer synthesis through Mistral/OpenRouter/OpenAI-compatible APIs.
# Do not commit real API keys. Put local secrets only into your private .env.
LLM_ENABLED=false
# Backward-compatible alias:
ENABLE_LLM=false
# LLM provider: auto | mistral | openrouter | yandex | offline | ollama | openai_compatible | groq
LLM_PROVIDER=offline
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_REFERER=http://localhost:8501
LLM_APP_TITLE=Scientific Knowledge Graph Demo
LLM_TIMEOUT_SECONDS=20

# Mistral Studio / La Plateforme
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_SECONDS=60
MISTRAL_MAX_TOKENS=1200
MISTRAL_TEMPERATURE=0.2

# Yandex AI Studio. Keep keys in local .env only.
YANDEX_API_KEY=
# YC_API_KEY is accepted as an alias when YANDEX_API_KEY is empty.
YC_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL_URI=
YANDEX_BASE_URL=https://ai.api.cloud.yandex.net/v1

# OpenRouter aliases. Keep these as fallback when LLM_PROVIDER=auto or when
# Mistral is unavailable and OpenRouter is configured.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free/cloud examples:
# Guarded Mistral polish: RUNTIME_PROFILE=economy_guarded_llm; ENABLE_LLM=true; LLM_PROVIDER=mistral; MISTRAL_MODEL=mistral-small-latest; MISTRAL_API_KEY=...
# Local hybrid retrieval: RUNTIME_PROFILE=balanced_hybrid; EXTRA_REQUIREMENTS=requirements-embeddings.txt
# OpenRouter: LLM_PROVIDER=openrouter; LLM_MODEL=openrouter/free; LLM_API_KEY=sk-or-...
# Yandex:     LLM_PROVIDER=yandex; YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt-5.1; YANDEX_API_KEY=...
# Groq:       LLM_PROVIDER=groq;       LLM_MODEL=llama-3.3-70b-versatile; LLM_API_KEY=gsk_...
