# Minimal resource profile: no LLM, no dense embeddings, no Qdrant projection.
RUNTIME_PROFILE=economy_core
RESOURCE_STRICT=false
RESOURCE_MAX_IMAGE_GB=5

EXTRA_REQUIREMENTS=requirements.txt
RETRIEVAL_MODE=bm25
ENABLE_LOCAL_EMBEDDINGS=false
EAGER_LOCAL_EMBEDDINGS=false
DIRECT_QDRANT_PROJECTION=false
ENABLE_LLM=false
LLM_PROVIDER=offline
ANSWER_SYNTHESIS_MODE=template
EXTRACTION_MODE=deterministic
EXTRACTION_ENABLE_LLM=false
